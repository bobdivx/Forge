---
// @ts-nocheck
import '../styles/global.css';
import AppLauncher from '../components/AppLauncher';
import AgentStats from '../components/AgentStats';
import WireLogs from '../components/WireLogs';
import fs from 'fs';
import path from 'path';

const vram = null;
const userEmail = String(Astro.locals?.user?.email ?? 'utilisateur');
const userInitial = userEmail.charAt(0).toUpperCase();
const agents = [
  'CHEF_TECHNIQUE',
  'ARCHITECTE_LOGICIEL',
  'DEV_BACKEND',
  'DEV_FRONTEND',
  'EXPERT_GITHUB',
  'ANALYSTE_CODE',
  'TESTEUR_QA',
  'INFRA_TECH',
  'REDACTEUR_DOC',
  'VEILLE_TECH',
  'SECURITE_CODE',
  'SCRIPTEUR_AUTOMATE',
  'INGENIEUR_PROMPT',
  'INGENIEUR_HARDWARE',
  'MAINTENANCE_REPO'
];

const githubPath = '/media/Github';
let deployedApps = [];

try {
  if (fs.existsSync(githubPath)) {
    const entries = fs.readdirSync(githubPath, { withFileTypes: true });
    deployedApps = entries
      .filter((entry) => entry.isDirectory() && !entry.name.startsWith('.'))
      .map((entry) => {
        const stats = fs.statSync(path.join(githubPath, entry.name));
        return {
          name: entry.name,
          status: 'Inconnu',
          lastDeploy: stats.mtime.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }),
          url: `${entry.name.toLowerCase()}.forge.local`
        };
      });
  }
} catch (e) {
  console.error('Failed to load apps', e);
}
---

<html lang="fr" class="h-full bg-slate-950">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard | DevForge SaaS</title>
  </head>
  <body class="flex h-full bg-slate-950 text-white font-sans antialiased overflow-hidden selection:bg-blue-500/30">
    
    <!-- Sidebar -->
    <aside class="flex w-64 flex-col bg-slate-900 border-r border-white/5 h-full relative z-20 shadow-2xl">
      <div class="flex h-16 shrink-0 items-center px-6 border-b border-white/5">
        <div class="flex items-center gap-2 cursor-pointer" onclick="window.location.href='/'">
          <div class="h-8 w-8 rounded bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center font-bold text-lg shadow-lg shadow-blue-500/20">F</div>
          <span class="text-xl font-bold tracking-tight text-white">DevForge</span>
        </div>
      </div>
      <nav class="flex flex-1 flex-col px-4 py-6 overflow-y-auto">
        <div class="space-y-1">
          <a href="/dashboard" class="bg-blue-500/10 text-blue-400 group flex items-center rounded-md px-3 py-2 text-sm font-medium border border-blue-500/20">
            <svg class="mr-3 h-5 w-5 flex-shrink-0 text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
            Vue d'ensemble
          </a>
          <a href="/apps" class="text-slate-400 hover:bg-slate-800 hover:text-white group flex items-center rounded-md px-3 py-2 text-sm font-medium transition">
          <a href="/swarm" class="text-slate-400 hover:bg-slate-800 hover:text-white group flex items-center rounded-md px-3 py-2 text-sm font-medium transition">
          <a href="/settings" class="text-slate-400 hover:bg-slate-800 hover:text-white group flex items-center rounded-md px-3 py-2 text-sm font-medium transition">
        </div>
        
        <div class="mt-8">
          <h3 class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Ressources Systèmes</h3>
          <div class="mt-4 px-3 space-y-4">
            <div>
              <div class="flex items-center justify-between text-xs text-slate-400 mb-1">
                <span>VRAM Usage</span>
                <span>{vram === null ? 'N/A' : `${vram}%`}</span>
              </div>
              <div class="h-2 w-full bg-slate-800 rounded-full overflow-hidden">
                <div class="h-full bg-blue-500 rounded-full" style={`width: ${vram ?? 0}%`}></div>
              </div>
            </div>
            <div>
              <div class="flex items-center justify-between text-xs text-slate-400 mb-1">
                <span>Charge GPU</span>
                <span>N/A</span>
              </div>
              <div class="h-2 w-full bg-slate-800 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-500 rounded-full" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>
      </nav>
      
      <!-- User profile bottom -->
      <div class="border-t border-white/5 p-4 flex items-center gap-3">
        <div class="h-9 w-9 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center font-bold text-sm text-slate-300">
          {userInitial}
        </div>
        <div class="flex flex-col">
          <span class="text-sm font-semibold text-white truncate max-w-[11rem]">{userEmail}</span>
          <span class="text-xs text-slate-500">Administrateur</span>
        </div>
      </div>
    </aside>

    <!-- Main View -->
    <main class="flex-1 flex flex-col h-full bg-slate-950 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-slate-900/40 via-transparent to-blue-950/30 pointer-events-none"></div>
      
      <!-- Top header -->
      <header class="h-16 flex items-center justify-between px-8 border-b border-white/5 bg-slate-950/50 backdrop-blur z-10">
        <h1 class="text-lg font-semibold text-white">Vue d'ensemble de la Forge</h1>
        <div class="flex items-center gap-4">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 text-xs font-medium text-emerald-400 border border-emerald-500/20 shadow-[0_0_10px_rgba(16,185,129,0.1)]">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            Ollama (qwen2.5:32b) Connecté
          </span>
          <a href="/api/auth/logout" class="bg-slate-800 hover:bg-slate-700 border border-slate-700 text-sm py-1.5 px-4 rounded-md transition font-medium">Deconnexion</a>
        </div>
      </header>

      <!-- Content -->
      <div class="flex-1 overflow-y-auto p-8 z-10">
        <div class="max-w-7xl mx-auto space-y-8">
          
          <div class="flex items-end justify-between">
            <div>
              <h2 class="text-2xl font-bold tracking-tight text-white">Vos Applications</h2>
              <p class="mt-1 text-sm text-slate-400">Applications gérées et déployées par les agents DevForge.</p>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left col: Project List & App Launcher -->
            <div class="lg:col-span-2 flex flex-col gap-6">
              
              <!-- Projects Grid -->
              {deployedApps.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {deployedApps.map(app => (
                    <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-blue-500/50 transition cursor-pointer group shadow-sm hover:shadow-lg">
                      <div class="flex justify-between items-start mb-4">
                        <div class="flex items-center gap-3">
                          <div class={`h-10 w-10 rounded-lg flex items-center justify-center font-bold text-lg border
                            ${app.status === 'Online' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 
                              app.status === 'Building' ? 'bg-blue-500/10 text-blue-400 border-blue-500/20' : 
                              'bg-slate-800 text-slate-400 border-slate-700'}`}>
                            {app.name.charAt(0).toUpperCase()}
                          </div>
                          <div>
                            <h3 class="font-semibold text-white group-hover:text-blue-400 transition">{app.name}</h3>
                            <a href={`http://${app.url}`} target="_blank" class="text-xs text-slate-400 hover:text-slate-300 transition">{app.url}</a>
                          </div>
                        </div>
                        <span class={`text-xs px-2 py-1 rounded-full border
                          ${app.status === 'Online' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' : 
                            app.status === 'Building' ? 'bg-blue-500/10 text-blue-400 border-blue-500/20 animate-pulse' : 
                            'bg-slate-800 text-slate-400 border-slate-700'}`}>
                          {app.status}
                        </span>
                      </div>
                      <div class="flex items-center text-xs text-slate-500">
                        <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Dernier déploiement: {app.lastDeploy}
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 text-sm text-slate-400">
                  Aucune application detectee dans <span class="font-mono text-blue-400">/media/Github</span>.
                </div>
              )}

              <!-- Wire Logs (Console feeling) -->
              <div class="mt-4">
                <WireLogs client:load />
              </div>

            </div>

            <!-- Right col: Actions & Agents -->
            <div class="space-y-6">
              
              <!-- App Launcher Tool -->
              <div class="bg-gradient-to-br from-slate-900 to-slate-800 border border-slate-700 shadow-xl rounded-xl p-[1px]">
                <div class="bg-slate-900 rounded-xl p-5 h-full relative overflow-hidden">
                  <div class="absolute -right-10 -top-10 w-32 h-32 bg-blue-600/20 rounded-full blur-[40px]"></div>
                  <AppLauncher client:load />
                </div>
              </div>

              <!-- Agents status list -->
              <AgentStats agents={agents} client:load />

            </div>
          </div>
          
        </div>
      </div>
    </main>
  </body>
</html>
