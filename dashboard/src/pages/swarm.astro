---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import SwarmGrid from '../components/SwarmGrid';
import SwarmInteractionsBoard from '../components/SwarmInteractionsBoard';
---
<DashboardLayout title="Essaim d'Agents" currentPath="/swarm">
  <div class="max-w-7xl mx-auto space-y-12">
    <div class="flex justify-between items-end flex-wrap gap-4">
      <div>
        <h2 class="text-3xl font-bold text-white mb-2 tracking-tight">Essaim &amp; interactions</h2>
        <p class="text-slate-400 max-w-2xl">
          Cartes des sessions actives, puis fil chronologique des échanges : liens principal → sub-agent
          (OpenClaw), messages <span class="font-mono text-slate-500">AgentMessage</span> et tâches{' '}
          <span class="font-mono text-slate-500">AgentTask</span> en base Forge.
        </p>
      </div>
    </div>

    <SwarmInteractionsBoard client:load />

    <section class="space-y-6">
      <div class="flex items-center gap-2 mb-2">
        <div class="w-1 h-6 bg-blue-500 rounded-full"></div>
        <h3 class="text-lg font-bold text-white uppercase tracking-widest text-sm">Cartes agents</h3>
      </div>
      <SwarmGrid client:load />
    </section>
  </div>
</DashboardLayout>
