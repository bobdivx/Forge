---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db, AgentTask, eq, desc } from 'astro:db';

const { id } = Astro.params;

// On récupère les tâches de la DB pour cet agent
const tasks = await db.select().from(AgentTask).where(eq(AgentTask.agentId, id || '')).orderBy(desc(AgentTask.createdAt));
---
<DashboardLayout title={`Agent ${id}`} currentPath="/swarm">
  <div class="max-w-7xl mx-auto space-y-8">
    <div class="flex items-center gap-4">
      <a href="/swarm" class="btn btn-ghost btn-sm border-slate-800 text-slate-400">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Retour
      </a>
      <h2 class="text-2xl font-bold text-white tracking-tight truncate">Gestion de l'Agent <span class="text-blue-400 font-mono">{`${id}`}</span></h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl">
          <div class="p-6 border-b border-slate-800 bg-slate-800/20">
            <h3 class="font-bold text-white flex items-center gap-2">
              <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              Historique des Tâches (Astro DB)
            </h3>
          </div>
          <div class="p-0">
            <table class="table table-zebra w-full">
              <thead>
                <tr class="text-slate-500 border-slate-800">
                  <th class="text-[10px] uppercase">Date</th>
                  <th class="text-[10px] uppercase">Tâche</th>
                  <th class="text-[10px] uppercase">Statut</th>
                </tr>
              </thead>
              <tbody>
                {tasks.length === 0 ? (
                  <tr>
                    <td colspan="3" class="text-center py-12 text-slate-500 italic">Aucune tâche enregistrée en base pour cet agent.</td>
                  </tr>
                ) : (
                  tasks.map((t) => (
                    <tr class="border-slate-800/50 hover:bg-slate-800/30 transition-colors cursor-default">
                      <td class="text-xs text-slate-400 whitespace-nowrap">{t.createdAt.toLocaleString('fr-FR')}</td>
                      <td class="text-xs font-semibold text-slate-200">
                        <div class="max-w-xs truncate" title={t.task}>{t.task}</div>
                        {t.input && <div class="text-[10px] text-slate-500 italic mt-0.5 truncate">{t.input.slice(0, 50)}...</div>}
                      </td>
                      <td>
                        <span class={`badge badge-xs ${t.status === 'success' ? 'badge-success' : t.status === 'running' ? 'badge-info animate-pulse' : t.status === 'error' ? 'badge-error' : 'badge-warning'}`}>
                          {t.status}
                        </span>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="lg:col-span-1 space-y-6">
         <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-xl space-y-6">
            <h3 class="font-bold text-white text-sm uppercase tracking-widest text-slate-500">Actions Rapides</h3>
            <div class="flex flex-col gap-3">
              <button class="btn btn-outline btn-error btn-sm w-full gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                Terminer la session
              </button>
              <button class="btn btn-primary btn-sm w-full gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                Envoyer un message
              </button>
            </div>
         </div>
      </div>
    </div>
  </div>
</DashboardLayout>
