---
// @ts-nocheck
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ProjectDemandesForm from '../../components/ProjectDemandesForm';
import { resolveProjectPath, isSafeRepoDirName } from '../../lib/forge-repos';
import { getGitCommits, getGitSummary } from '../../lib/project-git';
import { readForgeRequests } from '../../lib/project-requests';

const rawParam = Astro.params.app;
const appName = typeof rawParam === 'string' ? decodeURIComponent(rawParam) : '';

if (!isSafeRepoDirName(appName)) {
  return Astro.redirect('/apps');
}

const projectPath = resolveProjectPath(appName);

if (!projectPath) {
  return Astro.redirect('/apps');
}

const { commits, error: gitLogError } = getGitCommits(projectPath, 30);
const gitSummary = getGitSummary(projectPath);
const requests = readForgeRequests(projectPath);

const changes = commits.map((c) => ({
  title: c.subject,
  detail: `${c.shortHash} — ${c.hash}`,
  date: c.date,
  by: c.author,
}));

const lastSync = commits[0]?.date || '—';
const app = {
  name: appName,
  status: gitSummary.isRepo ? (gitSummary.dirty ? 'Modifications locales' : 'Dépôt Git') : 'Dépôt local',
  lastSync,
  url: `${appName.toLowerCase()}.forge.local`,
};
---

<DashboardLayout title={`Application: ${appName}`} currentPath="/apps">
  <div class="max-w-7xl mx-auto space-y-6">
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <a href="/apps" class="text-xs uppercase tracking-widest text-slate-400 hover:text-blue-400 transition">Retour aux applications</a>
          <h2 class="mt-2 text-2xl font-bold text-white">{appName}</h2>
          <p class="mt-1 text-[11px] font-mono text-slate-500 break-all">{projectPath}</p>
        </div>
        <div class="flex flex-col items-end gap-2">
          <span class="badge badge-success badge-outline py-3 px-3 text-xs uppercase">{app.status}</span>
          {gitSummary.isRepo && (
            <div class="text-right text-[11px] text-slate-500 font-mono space-y-0.5">
              <div>
                branche <span class="text-blue-400">{gitSummary.branch || '—'}</span>
                {gitSummary.dirty && <span class="text-amber-400 ml-2">● non commité</span>}
              </div>
              {gitSummary.aheadBehind && <div class="text-slate-400">{gitSummary.aheadBehind} vs upstream</div>}
              {gitSummary.error && <div class="text-amber-500">{gitSummary.error}</div>}
            </div>
          )}
        </div>
      </div>
    </div>

    {gitLogError && (
      <div class="bg-amber-500/10 border border-amber-500/30 rounded-xl p-4 text-sm text-amber-200">
        Git : {gitLogError}
      </div>
    )}

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
      <section class="xl:col-span-2 bg-slate-900 border border-slate-800 rounded-xl p-6">
        <div class="flex items-center justify-between mb-5 flex-wrap gap-2">
          <h3 class="text-lg font-semibold text-white">Historique Git</h3>
          <a href={`http://${app.url}`} target="_blank" rel="noopener noreferrer" class="text-xs text-blue-400 hover:text-blue-300 transition">{app.url}</a>
        </div>
        {changes.length > 0 ? (
          <div class="space-y-4">
            {changes.map((change) => (
              <article class="border border-slate-800 rounded-lg p-4 bg-slate-950/60">
                <div class="flex items-start justify-between gap-4">
                  <h4 class="font-medium text-white break-words">{change.title}</h4>
                  <span class="text-xs text-slate-500 shrink-0">{change.date}</span>
                </div>
                <p class="text-sm text-slate-400 mt-2 font-mono text-[11px]">{change.detail}</p>
                <p class="text-xs text-slate-500 mt-3">
                  Auteur : <span class="text-blue-400 font-mono">{change.by}</span>
                </p>
              </article>
            ))}
          </div>
        ) : (
          <div class="border border-slate-800 rounded-lg p-4 bg-slate-950/60 text-sm text-slate-400">
            {gitSummary.isRepo
              ? 'Aucun commit lisible (dépôt vide ou erreur git log).'
              : 'Initialisez un dépôt Git dans ce dossier pour afficher l’historique.'}
          </div>
        )}
      </section>

      <aside class="space-y-6">
        <ProjectDemandesForm client:load appName={appName} />

        <section class="bg-slate-900 border border-slate-800 rounded-xl p-6">
          <h3 class="text-sm font-bold uppercase tracking-widest text-slate-500 mb-4">File de demandes</h3>
          {requests.length > 0 ? (
            <div class="space-y-4">
              {requests.map((request) => (
                <article class="border border-slate-800 rounded-lg p-4 bg-slate-950/60">
                  <div class="flex items-center justify-between gap-3">
                    <p class="text-xs text-slate-500 font-mono">{request.id}</p>
                    <span
                      class={`text-[10px] uppercase font-semibold px-2 py-1 rounded border ${
                        request.status === 'Traite'
                          ? 'text-emerald-400 border-emerald-500/20 bg-emerald-500/10'
                          : request.status === 'En cours'
                            ? 'text-blue-400 border-blue-500/20 bg-blue-500/10'
                            : 'text-amber-400 border-amber-500/20 bg-amber-500/10'
                      }`}
                    >
                      {request.status}
                    </span>
                  </div>
                  <p class="mt-2 text-sm text-white">{request.title}</p>
                  {request.detail && <p class="mt-2 text-xs text-slate-500">{request.detail}</p>}
                  <p class="mt-2 text-xs text-slate-400">
                    Type : <span class="text-slate-300">{request.type}</span>
                  </p>
                  <p class="text-xs text-slate-400">
                    Agent : <span class="text-blue-400 font-mono">{request.agent}</span>
                  </p>
                  <p class="text-xs text-slate-500 mt-2">
                    {new Date(request.updatedAt).toLocaleString('fr-FR')}
                  </p>
                </article>
              ))}
            </div>
          ) : (
            <div class="border border-slate-800 rounded-lg p-4 bg-slate-950/60 text-sm text-slate-400">
              Aucune entrée dans <span class="font-mono text-slate-500">.forge/demandes.json</span>. Utilisez le formulaire ci-dessus.
            </div>
          )}
        </section>
      </aside>
    </div>
  </div>
</DashboardLayout>
