---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import NeedsFromOpenClaw from '../components/NeedsFromOpenClaw';
---
<DashboardLayout title="Demandes Systèmes" currentPath="/needs">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-8">
      <div>
        <h2 class="text-2xl font-bold text-white mb-2">Agents & modèles (OpenClaw)</h2>
        <p class="text-slate-400">
          Vue dérivée des sessions actuellement connues du gateway : pas de liste d’outils inventée.
        </p>
      </div>
    </div>

    <NeedsFromOpenClaw client:load />
  </div>
</DashboardLayout>
