---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import ReportsFromOpenClaw from '../components/ReportsFromOpenClaw';
---
<DashboardLayout title="Rapports d'Agents" currentPath="/reports">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-2xl font-bold text-white mb-2">Rapports & mémoire</h2>
    <p class="text-slate-400 mb-8">
      Résumé des sessions via OpenClaw ; fichiers <code class="text-slate-300">MEMORY.md</code> /{' '}
      <code class="text-slate-300">USER.md</code> si <code class="text-slate-300">FORGE_OPENCLAW_WORKSPACE</code>{' '}
      pointe vers le workspace (ex. copie du dossier workspace OpenClaw).
    </p>

    <ReportsFromOpenClaw client:load />
  </div>
</DashboardLayout>
