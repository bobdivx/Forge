---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import OrchestrationJournal from '../components/OrchestrationJournal';
---
<DashboardLayout title="Orchestration" currentPath="/orchestration">
  <div class="max-w-7xl mx-auto space-y-8">
    <div>
      <h2 class="text-3xl font-bold text-white mb-2 tracking-tight">Journal d'Orchestration</h2>
      <p class="text-slate-400">
        Données issues des sessions OpenClaw (gateway). Aucun ordre fictif : une ligne par session connue.
      </p>
    </div>

    <div class="bg-slate-900/50 border border-slate-800 rounded-xl overflow-hidden shadow-2xl backdrop-blur-sm">
      <OrchestrationJournal client:load />
    </div>
  </div>
</DashboardLayout>
