# Copier vers .env et adapter (non commité — voir .gitignore).

# Forge → Gateway OpenClaw (API). Même machine : 127.0.0.1 suffit.
# Forge en Docker, OpenClaw sur l’hôte : souvent http://172.17.0.1:18789 (Linux) ou host.docker.internal (Docker Desktop).
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Doit correspondre à gateway.auth.token dans AppData/openclaw/openclaw.json
OPENCLAW_GATEWAY_TOKEN=
