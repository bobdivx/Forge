---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import AgentStats from '../components/AgentStats';
import SwarmActivities from '../components/SwarmActivities';
---
<DashboardLayout title="Essaim d'Agents" currentPath="/swarm">
  <div class="max-w-7xl mx-auto space-y-8">
    <div class="flex justify-between items-end flex-wrap gap-4">
      <div>
        <h2 class="text-3xl font-bold text-white mb-2 tracking-tight">État de l'Essaim</h2>
        <p class="text-slate-400">
          Supervision branchée sur le gateway OpenClaw (sessions réelles, pas de scénario de démo).
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
      <div class="xl:col-span-1">
        <AgentStats client:load />
      </div>

      <div class="xl:col-span-2 space-y-6">
        <SwarmActivities client:load />
      </div>
    </div>
  </div>
</DashboardLayout>
